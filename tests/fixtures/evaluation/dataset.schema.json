{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetily-memory.local/schemas/evaluation-dataset-v1.json",
  "title": "Meetily Memory retrieval evaluation dataset",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "dataset_version", "name", "tasks"],
  "properties": {
    "schema_version": {"const": "meetily-memory.eval.v1"},
    "dataset_version": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "query", "class", "critical", "critical_reason", "expected"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "query": {"type": "string", "minLength": 1},
          "class": {
            "enum": [
              "exact_match",
              "fuzzy_recall",
              "decision",
              "task",
              "risk",
              "person",
              "project",
              "neighbor_context"
            ]
          },
          "critical": {"type": "boolean"},
          "critical_reason": {"type": ["string", "null"]},
          "expected": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["evidence_id", "relevance"],
              "properties": {
                "evidence_id": {"type": "string", "minLength": 3},
                "relevance": {"enum": [1, 2]}
              }
            }
          }
        }
      }
    }
  }
}
